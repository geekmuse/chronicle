# EditorConfig — chronicle
# https://editorconfig.org

root = true

# Global defaults
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown — preserve trailing whitespace (line breaks)
[*.md]
trim_trailing_whitespace = false

# YAML
[*.{yml,yaml}]
indent_size = 2

# TOML
[*.toml]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# Shell scripts
[*.sh]
indent_size = 2

# Makefile — requires tabs
[Makefile]
indent_style = tab

# Rust
[*.rs]
indent_size = 4
