# Normalize line endings
* text=auto

# Force LF for text files
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.sh text eol=lf

# Rust
*.rs text eol=lf
Cargo.toml text eol=lf
Cargo.lock text eol=lf

# Binary files — do not diff
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
